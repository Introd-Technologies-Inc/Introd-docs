{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Introd",
  "description": "User documentation for getting set up, finding warm paths, requesting introductions, and understanding how Introd makes trust decisions.",
  "icons": {
    "library": "lucide"
  },
  "colors": {
    "primary": "#08AE7E",
    "light": "#57E3BA",
    "dark": "#08976E"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#F6FBF8",
      "dark": "#07131A"
    }
  },
  "fonts": {
    "family": "Inter",
    "weight": 450
  },
  "logo": {
    "light": "/images/brand/logo-light.png",
    "dark": "/images/brand/logo-dark.png",
    "href": "/getting-started/quickstart"
  },
  "favicon": {
    "light": "/images/brand/favicon.png",
    "dark": "/images/brand/favicon.png"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/getting-started/quickstart"
    }
  ],
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://getintrod.ai"
      },
      {
        "label": "FAQ",
        "href": "/faq"
      },
      {
        "label": "Trust",
        "href": "/privacy-security"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.getintrod.ai"
    }
  },
  "footer": {
    "links": [
      {
        "title": "Docs",
        "items": [
          {
            "label": "Getting started",
            "href": "/getting-started/quickstart"
          },
          {
            "label": "Chrome extension",
            "href": "/chrome-extension"
          },
          {
            "label": "API reference",
            "href": "/api"
          }
        ]
      },
      {
        "title": "Company",
        "items": [
          {
            "label": "Introd",
            "href": "https://getintrod.ai"
          },
          {
            "label": "App",
            "href": "https://app.getintrod.ai"
          }
        ]
      }
    ],
    "socials": {
      "linkedin": "https://www.linkedin.com/company/introd-ai"
    }
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.getintrod.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "root": "getting-started/quickstart",
            "pages": [
              "getting-started/index",
              "getting-started/create-account",
              "getting-started/connect-integrations",
              "getting-started/first-warm-introduction",
              "faq/index",
              "getting-started/definitions"
            ],
            "public": true
          },
          {
            "group": "Workspace",
            "icon": "layout-dashboard",
            "root": "workspace/home",
            "pages": [
              "workspace/saved-lists",
              "workspace/missions"
            ],
            "public": true
          },
          {
            "group": "Setup Network",
            "icon": "user-round-cog",
            "root": "setup-network/index",
            "pages": [
              "setup-network/sync-accounts",
              "setup-network/import-contacts",
              "setup-network/alumni-networks",
              "setup-network/groups"
