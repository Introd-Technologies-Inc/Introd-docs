            "public": true
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "square-terminal",
        "groups": [
          {
            "group": "API Reference",
            "icon": "square-terminal",
            "root": "api/index",
            "pages": [
              "api/authentication",
              "api/graph-apis",
              "api/people-apis",
              "api/companies-apis",
              "api/intro-apis",
              {
                "group": "Generated Inventories",
                "icon": "folder-kanban",
                "expanded": false,
                "pages": [
                  "reference/generated/api-endpoint-inventory",
                  "reference/generated/environment-variables"
                ],
                "public": true
              }
            ],
            "public": true
          }
        ]
      },
      {
        "tab": "Developers",
        "icon": "blocks",
        "groups": [
          {
            "group": "Local Setup",
            "icon": "terminal",
            "root": "quickstart",
            "pages": [],
            "public": true
          },
          {
            "group": "Architecture",
            "icon": "blocks",
            "root": "architecture/index",
            "pages": [
              "architecture/neograph",
